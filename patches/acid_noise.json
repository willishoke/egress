{
  "schema": "tropical_program_2",
  "name": "acid_noise",
  "body": {
    "op": "block",
    "decls": [
      {
        "op": "instanceDecl",
        "name": "ClockStep",
        "program": "Clock",
        "inputs": {
          "freq": 8
        }
      },
      {
        "op": "instanceDecl",
        "name": "ClockBeat",
        "program": "Clock",
        "inputs": {
          "freq": 2
        }
      },
      {
        "op": "instanceDecl",
        "name": "ClockHat",
        "program": "Clock",
        "inputs": {
          "freq": 4
        }
      },
      {
        "op": "instanceDecl",
        "name": "ClockFast",
        "program": "Clock",
        "inputs": {
          "freq": 8000
        }
      },
      {
        "op": "instanceDecl",
        "name": "PowBassFreq",
        "program": "Pow",
        "inputs": {
          "x": 2,
          "y": {
            "op": "add",
            "args": [
              {
                "op": "mul",
                "args": [
                  0.25,
                  {
                    "op": "gt",
                    "args": [
                      {
                        "op": "ref",
                        "instance": "VCOBit0",
                        "output": "saw"
                      },
                      0
                    ]
                  }
                ]
              },
              {
                "op": "mul",
                "args": [
                  0.583,
                  {
                    "op": "gt",
                    "args": [
                      {
                        "op": "ref",
                        "instance": "VCOBit1",
                        "output": "saw"
                      },
                      0
                    ]
                  }
                ]
              }
            ]
          }
        }
      },
      {
        "op": "instanceDecl",
        "name": "VCOBass",
        "program": "BlepSaw",
        "inputs": {
          "freq": {
            "op": "mul",
            "args": [
              55,
              {
                "op": "ref",
                "instance": "PowBassFreq",
                "output": "out"
              }
            ]
          }
        }
      },
      {
        "op": "instanceDecl",
        "name": "VCOBit0",
        "program": "BlepSaw",
        "inputs": {
          "freq": 0.47
        }
      },
      {
        "op": "instanceDecl",
        "name": "VCOBit1",
        "program": "BlepSaw",
        "inputs": {
          "freq": 0.97
        }
      },
      {
        "op": "instanceDecl",
        "name": "EnvBassAmp",
        "program": "EnvExpDecay",
        "inputs": {
          "decay": 0.9995,
          "trigger": {
            "op": "ref",
            "instance": "ClockStep",
            "output": "output"
          }
        }
      },
      {
        "op": "instanceDecl",
        "name": "EnvBassFilt",
        "program": "EnvExpDecay",
        "inputs": {
          "decay": 0.9995,
          "trigger": {
            "op": "ref",
            "instance": "ClockStep",
            "output": "output"
          }
        }
      },
      {
        "op": "instanceDecl",
        "name": "FiltBass",
        "program": "LadderFilter",
        "inputs": {
          "input": {
            "op": "ref",
            "instance": "VCOBass",
            "output": "saw"
          },
          "cutoff": {
            "op": "add",
            "args": [
              300,
              {
                "op": "mul",
                "args": [
                  5200,
                  {
                    "op": "ref",
                    "instance": "EnvBassFilt",
                    "output": "env"
                  }
                ]
              }
            ]
          },
          "resonance": 0.88,
          "drive": 3.5
        }
      },
      {
        "op": "instanceDecl",
        "name": "HatNoise",
        "program": "NoiseLFSR",
        "inputs": {
          "clock": {
            "op": "ref",
            "instance": "ClockFast",
            "output": "output"
          }
        }
      },
      {
        "op": "instanceDecl",
        "name": "EnvHat",
        "program": "EnvExpDecay",
        "inputs": {
          "decay": 0.9995,
          "trigger": {
            "op": "ref",
            "instance": "ClockHat",
            "output": "output"
          }
        }
      },
      {
        "op": "instanceDecl",
        "name": "VCABass",
        "program": "VCA",
        "inputs": {
          "audio": {
            "op": "ref",
            "instance": "FiltBass",
            "output": "lp"
          },
          "cv": {
            "op": "mul",
            "args": [
              0.75,
              {
                "op": "ref",
                "instance": "EnvBassAmp",
                "output": "env"
              }
            ]
          }
        }
      },
      {
        "op": "instanceDecl",
        "name": "VCAHat",
        "program": "VCA",
        "inputs": {
          "audio": {
            "op": "ref",
            "instance": "HatNoise",
            "output": "out"
          },
          "cv": {
            "op": "mul",
            "args": [
              0.25,
              {
                "op": "ref",
                "instance": "EnvHat",
                "output": "env"
              }
            ]
          }
        }
      }
    ],
    "assigns": [],
    "value": null
  },
  "audio_outputs": [
    {
      "instance": "VCABass",
      "output": "out"
    },
    {
      "instance": "VCAHat",
      "output": "out"
    }
  ]
}
